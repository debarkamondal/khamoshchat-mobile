{
  "name": "khamoshchat-mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "cargo-build-ios": "bun ./scripts/cargo-ios.ts",
    "cargo-build-android": "bun ./scripts/cargo-android.ts",
    "android": "bun ./scripts/cargo-android.ts && expo run:android",
    "ios": "bun ./scripts/cargo-ios.ts --target='ios' && expo run:ios",
    "ios-sim": "bun ./scripts/cargo-ios.ts --target='ios-sim' && expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@noble/curves": "^2.0.1",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.8.0",
    "@react-navigation/native": "^7.1.8",
    "expo": "^55.0.0",
    "expo-blur": "~55.0.8",
    "expo-constants": "~55.0.7",
    "expo-contacts": "~55.0.8",
    "expo-crypto": "~55.0.8",
    "expo-dev-client": "~55.0.9",
    "expo-font": "~55.0.4",
    "expo-glass-effect": "~55.0.7",
    "expo-haptics": "~55.0.8",
    "expo-image": "~55.0.5",
    "expo-linking": "~55.0.7",
    "expo-router": "~55.0.2",
    "expo-secure-store": "~55.0.8",
    "expo-splash-screen": "~55.0.9",
    "expo-sqlite": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.4",
    "expo-system-ui": "~55.0.9",
    "expo-web-browser": "~55.0.9",
    "mqtt": "^5.14.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.7.2",
    "uuid": "^13.0.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@types/react": "~19.2.10",
    "@types/uuid": "^11.0.0",
    "eslint": "^9.38.0",
    "eslint-config-expo": "~55.0.0",
    "typescript": "~5.9.3"
  },
  "private": true
}